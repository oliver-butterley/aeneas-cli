{
  "name": "aeneas-cli",
  "version": "0.1.0",
  "description": "CLI tool for managing Aeneas extraction from Rust to Lean",
  "type": "module",
  "bin": {
    "aeneas-cli": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "aeneas",
    "charon",
    "lean",
    "lean4",
    "rust",
    "formal-verification",
    "extraction"
  ],
  "author": "Oliver Butterley",
  "repository": {
    "type": "git",
    "url": "https://github.com/oliver-butterley/aeneas-cli.git"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "execa": "^9.5.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
